{
  "model": "blog.post",
  "pk": 5,
  "fields": {
    "title": "What is django",
    "slug": "what-is-django",
    "author": 1,
    "body": "Django is a free and open-source, high-level Python web framework designed to facilitate rapid development and encourage clean, pragmatic design. It adheres to the \"Don't Repeat Yourself\" (DRY) principle, providing a structured framework and pre-built components to handle many common web development tasks.",
