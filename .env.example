# Environment Variables for PostCraft Django Blog
# Copy this to .env and set your actual values

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Configuration
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
EMAIL_TIMEOUT=30

# Production Email Backend Options:
# EMAIL_BACKEND=blog.email_backend.FixedSMTPBackend  # For real email sending
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend  # For development
# EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend  # Save to files